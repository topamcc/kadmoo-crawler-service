# ── Server ──────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# ── Security ────────────────────────────────────────────
# Static API key shared with the web app (generate: openssl rand -hex 32)
CRAWLER_API_KEY=change-me-generate-a-real-key

# HMAC secret for signing webhook payloads (generate: openssl rand -hex 32)
WEBHOOK_HMAC_SECRET=change-me-generate-a-real-secret

# ── Redis (BullMQ) ─────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Web App Callback ───────────────────────────────────
# Base URL of the main Kadmoo web app for webhook callbacks
WEB_APP_BASE_URL=https://your-app.vercel.app

# ── S3-Compatible Object Storage ───────────────────────
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=nyc3
S3_BUCKET=kadmoo-crawl-artifacts
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

# ── Crawl Defaults ─────────────────────────────────────
DEFAULT_MAX_PAGES=200
DEFAULT_MAX_DEPTH=10
DEFAULT_CONCURRENCY=8
DEFAULT_TIMEOUT_MS=15000
DEFAULT_MAX_DURATION_MINUTES=30

# ── Budget / Quotas ────────────────────────────────────
MAX_CONCURRENT_JOBS=5
MAX_PAGES_PER_SITE_DAILY=5000

# ── Playwright (optional, set to "true" to enable) ────
PLAYWRIGHT_ENABLED=true
